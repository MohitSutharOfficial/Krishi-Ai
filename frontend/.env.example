# Backend API URL
VITE_API_URL=http://localhost:5000

# ML Flask Server URL
VITE_ML_API_URL=http://localhost:5050

# ML Server API Key (must match ML_API_KEY on ML server)
VITE_ML_API_KEY=your_ml_api_key_here

# OpenWeatherMap API Key (for rainfall prediction weather fetch)
# Get your key from: https://openweathermap.org/api
VITE_OPENWEATHER_KEY=your_openweather_api_key_here
