# MongoDB connection string
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/krishiai?retryWrites=true&w=majority

# JWT Secret (change this in production!)
JWT_SECRET=your_jwt_secret_key_here

# Server port
PORT=5000

# Environment
NODE_ENV=development

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.pages.dev

# Google Gemini API Key (for AI chatbot feature)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
